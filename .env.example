# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=authsphere.veltech.edu.in
JWT_ACCESS_TOKEN_EXPIRES_IN=1800
JWT_REFRESH_TOKEN_EXPIRES_IN=604800

# ─── REDIS ────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379 | Upstash: rediss://...
REDIS_URL=redis://localhost:6379

# ─── AUTH SERVER ──────────────────────────────────────────────────────────────
AUTH_SERVER_PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Email domain restriction for campus accounts
CAMPUS_DOMAIN=veltech.edu.in
# Dev-only: allow auth flows without DB connectivity
AUTH_NO_DB=false

# ─── WEBAUTHN / FIDO2 ─────────────────────────────────────────────────────────
RP_ID=localhost
RP_NAME=AuthSphere VelTech Campus
RP_ORIGIN=http://localhost:5173
# Backwards-compat (older backend builds used ORIGIN instead of RP_ORIGIN)
ORIGIN=http://localhost:5173

# ─── SMTP (Email OTP Delivery) ────────────────────────────────────────────────
# Use Gmail, Resend, or any SMTP. If blank, dev mode uses Ethereal test account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dreammasterorigin@gmail.com
SMTP_PASS=muml magy wgxv mlxb
SMTP_FROM="AuthSphere VelTech <noreply@veltech.edu.in>"

# ─── OTP SETTINGS ─────────────────────────────────────────────────────────────
